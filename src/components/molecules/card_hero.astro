---
const { title, video, class: className } = Astro.props;
---

<div class={`flex flex-col  items-center gap-3 ${className}`}>
    <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-brand-primary"></span>
        <p class="text-xs md:text-sm font-medium text-black-500 whitespace-nowrap">{title}</p>
    </div>
    <div class="w-full h-full overflow-hidden rounded-lg lg:rounded-4xl bg-gray-300">
        <video src={video}
        autoplay
        muted
        loop
        playsinline
        webkit-playsinline
        class="w-full h-full object-cover">
        </video>
    </div>
</div>