---
import "../styles/global.css";

const mobileImages = [
  {
    src: "https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=600&auto=format&fit=crop",
    alt: "Fotografía de Bodas"
  },
  {
    src: "https://images.unsplash.com/photo-1555244162-803834f70033?q=80&w=600&auto=format&fit=crop",
    alt: "Eventos y Gastronomía"
  },
  {
    src: "https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=600&auto=format&fit=crop",
    alt: "Bodas 2"
  },
  {
    src: "https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=600&auto=format&fit=crop",
    alt: "Eventos 2"
  }
];
const teamText = "At Ruana Soul Studio, we capture the essence of your unforgettable moments. With a cinematic and creative approach, we turn every wedding and every event into a visual work of art that will last forever.";
const teamWords = teamText.split(" ");
// Indices para "cinematic and creative approach," (14 a 17) y "visual work of art" (27 a 30)
const isPrimary = (index: number) => (index >= 14 && index <= 17) || (index >= 27 && index <= 30);
---

<section id="our-team" class="relative w-full min-h-screen overflow-hidden flex items-center justify-center py-8 lg:py-0 px-4 md:px-8 lg:px-16">
  <article class="relative w-full max-w-[1400px] mx-auto flex flex-col items-center justify-center min-h-[80vh]">
    
    <!-- Imagen 1: Top Left -->
    <div class="hidden md:block absolute left-[15%] top-[10%] w-[25%] max-w-[250px] aspect-video z-10 parallax-img-1">
      <img src="https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=600&auto=format&fit=crop" alt="Fotografía de Bodas 1" class="w-full h-full object-cover shadow-2xl transition-transform duration-500 ease-out hover:scale-[1.5] hover:rotate-5 cursor-pointer" />
    </div>

    <!-- Imagen 2: Bottom Right -->
    <div class="hidden md:block absolute right-[0%] bottom-[-7%] w-[25%] max-w-[250px] aspect-video z-10 parallax-img-2">
      <img src="https://images.unsplash.com/photo-1555244162-803834f70033?q=80&w=600&auto=format&fit=crop" alt="Eventos 1" class="w-full h-full object-cover shadow-2xl transition-transform duration-500 ease-out hover:scale-[1.5] hover:rotate-[-5deg] cursor-pointer" />
    </div>

    <!-- Imagen 3: Top Right -->
    <div class="hidden md:block absolute right-[15%] top-[6%] w-[25%] max-w-[250px] aspect-video z-10 parallax-img-3">
      <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=600&auto=format&fit=crop" alt="Bodas 2" class="w-full h-full object-cover shadow-2xl transition-transform duration-500 ease-out hover:scale-[1.5] hover:rotate-[-5deg] cursor-pointer" />
    </div>

    <!-- Imagen 4: Bottom Left -->
    <div class="hidden md:block absolute left-[0%] bottom-[-12%] w-[25%] max-w-[250px] aspect-video z-10 parallax-img-4">
      <img src="https://images.unsplash.com/photo-1511795409834-ef04bbd61622?q=80&w=600&auto=format&fit=crop" alt="Eventos 2" class="w-full h-full object-cover shadow-2xl transition-transform duration-500 ease-out hover:scale-[1.5] hover:rotate-5 cursor-pointer" />
    </div>

    <!-- Texto central animado (con mix-blend-difference individual) -->
    <div class="text-center parallax-text w-full lg:px-24 pointer-events-none">
      <h2 class="text-2xl lg:text-5xl leading-[1.2] mx-auto font-black uppercase parallax-text-container">
        {teamWords.map((word, index) => (
          <><span class={`relative z-20 inline-block team-word opacity-0 translate-y-8 ${isPrimary(index) ? 'text-brand-primary' : 'text-white mix-blend-difference'}`}>{word}</span>{index !== teamWords.length - 1 && " "}</>
        ))}
      </h2>
    </div>

    <!-- Imágenes para móvil (sin absolute para no solapar si la pantalla es chica) -->
    <div class="flex md:hidden flex-col gap-4 mt-12 w-full z-10">
      {mobileImages.map((img) => (
        <div class="w-full aspect-video mobile-fade-img opacity-0">
          <img src={img.src} alt={img.alt} class="w-full h-full object-cover shadow-xl" />
        </div>
      ))}
    </div>

  </article>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Asegurarse de que el script corra en el cliente
  if (typeof window !== "undefined") {
    gsap.registerPlugin(ScrollTrigger);

    // Animación de aparición del texto palabra por palabra
    gsap.to(".team-word", {
      opacity: 1,
      y: 0,
      duration: 0.8,
      stagger: 0.05, // Intervalo entre cada palabra
      ease: "power3.out",
      scrollTrigger: {
        trigger: ".parallax-text-container",
        start: "top 85%", // Cuando el contenedor entra al 85% de la pantalla
        toggleActions: "play none none reverse" // Opcional: reproduce al bajar, revierte al subir si quieres. Si solo quieres una vez, "play none none none"
      }
    });

    // Parallax muy acentuado para Imagen 1
    gsap.fromTo(".parallax-img-1",
      { y: 150, 
		rotation: 10 },
      {
        y: -300,
        rotation: -15,
        ease: "none",
        scrollTrigger: {
          trigger: "#our-team",
          start: "top bottom",
          end: "bottom top",
          scrub: true,
        }
      }
    );

    // Parallax muy acentuado para Imagen 2
    gsap.fromTo(".parallax-img-2",
      { y: 350, rotation: -10 },
      {
        y: -400,
        rotation: 15,
        ease: "none",
        scrollTrigger: {
          trigger: "#our-team",
          start: "top bottom",
          end: "bottom top",
          scrub: true,
        }
      }
    );

    // Parallax muy acentuado para Imagen 3 (más lento que la 1)
    gsap.fromTo(".parallax-img-3",
      { y: 100, rotation: -10 },
      {
        y: -200,
        rotation: 15,
        ease: "none",
        scrollTrigger: {
          trigger: "#our-team",
          start: "top bottom",
          end: "bottom top",
          scrub: true,
        }
      }
    );

    // Parallax muy acentuado para Imagen 4 (rápido y en dirección contraria? no, todos hacia arriba, solo distintas velocidades)
    gsap.fromTo(".parallax-img-4",
      { y: 250, rotation: 10 },
      {
        y: -350,
        rotation: -15,
        ease: "none",
        scrollTrigger: {
          trigger: "#our-team",
          start: "top bottom",
          end: "bottom top",
          scrub: true,
        }
      }
    );

    // Fade in para las imágenes en móvil al hacer scroll
    gsap.utils.toArray(".mobile-fade-img").forEach((img: any) => {
      gsap.to(img, {
        opacity: 1,
        y: 0,
        duration: 1,
        ease: "power2.out",
        scrollTrigger: {
          trigger: img,
          start: "top 80%",
          end: "top 50%",
          scrub: 1,
        }
      });
      // Añadimos un pequeño from para que vengan desde abajo suavemente
      gsap.set(img, { y: 50 });
    });
  }
</script>
