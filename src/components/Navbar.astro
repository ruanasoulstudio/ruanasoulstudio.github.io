        <path class="splash-letter" d="M97.7,14.71c-.02-3.84,2.2-7.22,5.48-8.83,6.41-3.14,14.08,1.47,14.08,8.79v10.18c0,1.72.65,3.35,1.81,4.62h-9.75v-4.17c-1.55,2.04-3.91,4.17-7.03,4.17-6,0-6.44-7.87-2.16-10.42,3.31-1.98,7.48-3.89,9.19-4.65v-5.39c0-1.72-1.39-3.12-3.11-3.13-2.53-.02-4.02,2.82-2.62,4.89l-5.9,3.94ZM109.33,22.69v-6.86c-9.18,6.24-2.8,10.13,0,6.86Z" fill="#961728"/>
        <path class="splash-letter" d="M.76,52.21s5.97,10.57,13.39,12.58c7.42,2.02,7.47-1.62,5.7-3-1.77-1.38-19.1-9-19.1-16.08,0-6.31,4.66-7.59,10.81-7.79,4.64-.15,12.42,1.98,12.42,5.39v7.37s-13.38-14.21-17.76-10.72c-5.96,4.75,17.76,8.98,17.76,19.22,0,5.46-3.41,8.17-11.32,8.17s-11.92-2.62-11.92-2.62v-12.53Z" fill="#961728"/>
        <path class="splash-letter" d="M50.26,55.07c0,6.79-5.5,12.29-12.29,12.29s-12.29-5.5-12.29-12.29,5.5-12.29,12.29-12.29,12.29,5.5,12.29,12.29ZM42.92,45.44c-2.28-1.48-6.34,1.64-9.07,6.96-2.73,5.32-3.1,10.84-.82,12.32,2.28,1.48,6.34-1.64,9.07-6.96s3.1-10.84.82-12.32Z" fill="#961728"/>
        <path class="splash-letter" d="M52.96,60.1v-12.7c0-1.72-.65-3.35-1.81-4.62h9.81c0,6.72-.07,13.44-.07,20.16-.03.14-.05.29-.05.44,0,1.1.89,2.01,2.01,2.01s2.01-.9,2.01-2.01v-20.6h9.75c-1.16,1.26-1.8,2.9-1.81,4.62v15.35c0,1.72.65,3.35,1.81,4.62h-9.75v-1.68c-4.67,3.89-11.91.62-11.91-5.59Z" fill="#961728"/>
        <path class="splash-letter" d="M85.24,37.89v24.85c0,1.72.65,3.35,1.81,4.62h-11.55c1.16-1.26,1.8-2.9,1.81-4.62v-18.84c0-1.72-.65-3.36-1.81-4.62l9.75-1.39Z" fill="#961728"/>
        <path class="splash-letter" d="M.76,90.11s5.97,10.57,13.39,12.58c7.42,2.02,7.47-1.62,5.7-3-1.77-1.38-19.1-9-19.1-16.08,0-6.31,4.66-7.59,10.81-7.79,4.64-.15,12.42,1.98,12.42,5.39v7.37s-13.38-14.21-17.76-10.72c-5.96,4.75,17.76,8.98,17.76,19.22,0,5.46-3.41,8.17-11.32,8.17s-11.92-2.62-11.92-2.62v-12.53Z" fill="#961728"/>
        <path class="splash-letter" d="M35.26,99.55c0,2.27,2.7,3.45,4.37,1.94-.82,1.78-2.42,3.13-4.37,3.59-4.03.96-7.94-2.09-7.94-6.27v-14.9l-2.02-1.72h2.02l7.94-6.4v6.4h4.37v1.72h-4.37v15.64Z" fill="#961728"/>
        <path class="splash-letter" d="M42.02,97.99v-12.7c0-1.72-.65-3.35-1.81-4.62h9.81c0,6.72-.07,13.44-.07,20.16-.03.14-.05.29-.05.44,0,1.1.89,2.01,2.01,2.01s2.01-.9,2.01-2.01v-20.6h9.75c-1.16,1.26-1.8,2.9-1.81,4.62v15.35c0,1.72.65,3.35,1.81,4.62h-9.75v-1.68c-4.67,3.89-11.91.62-11.91-5.59Z" fill="#961728"/>
        <path class="splash-letter" d="M88.47,75.79c-1.16,1.26-1.8,2.9-1.81,4.62v20.24c0,1.72.65,3.35,1.81,4.62h-9.75v-3.45c-1.59,2.25-3.81,3.61-6.24,3.43-4.42-.33-7.94-5.7-7.94-12.27s3.69-12.29,8.37-12.29c2.26,0,4.31,1.31,5.81,3.45v-3.72c0-1.72-.65-3.35-1.81-4.62h11.55ZM75.6,102.99c1.72,0,3.12-4.49,3.12-10.03s-1.4-10.03-3.12-10.03-3.12,4.49-3.12,10.03c0,5.54,1.4,10.03,3.12,10.03Z" fill="#961728"/>
        <path class="splash-letter" d="M99.09,100.64c0,1.72.65,3.35,1.81,4.62h-11.55c1.16-1.26,1.8-2.9,1.81-4.62v-13.77c0-1.72-.65-3.36-1.81-4.62h11.55c-1.16,1.26-1.8,2.9-1.81,4.62v13.77ZM95.12,75.79c2.19,0,3.97,1.1,3.97,2.44s-1.78,2.44-3.97,2.44-3.97-1.1-3.97-2.44,1.78-2.44,3.97-2.44Z" fill="#961728"/>
        <path class="splash-letter" d="M126.3,92.97c0,6.79-5.5,12.29-12.29,12.29s-12.29-5.5-12.29-12.29,5.5-12.29,12.29-12.29,12.29,5.5,12.29,12.29ZM118.95,83.33c-2.28-1.48-6.34,1.64-9.07,6.96-2.73,5.32-3.1,10.84-.82,12.32,2.28,1.48,6.34-1.64,9.07-6.96s3.1-10.84.82-12.32Z" fill="#961728"/>
    </svg>
</div>

<nav
    id="navbar"
    class="flex fixed left-0 right-0 justify-between items-center h-auto w-full z-50 top-0 pr-4 lg:pr-0 max-w-[1920px] mx-auto"
>
    <a
        id="logo-link"
        href="/"
        
    >
        <img
            class="w-[80px] px-6 py-4 h-full"
            src={logotipo.src}
            alt="logotipo wisegold"
            id="logo__top"
        />
    </a>

    <ul id="menu-desktop" class="hidden lg:flex gap-6">
        <Item__menu class="menu-item" title="Our Team" link="#team" />
        <Item__menu class="menu-item" title="Branding" link="#branding" />
        <Item__menu class="menu-item" title="Web Creator" link="#web" />
        <Item__menu class="menu-item" title="Photography" link="#photography" />
        <Item__menu class="menu-item" title="Videography" link="#videography" />
        <Item__menu class="menu-item" title="Social Content" link="#social" />
    </ul>

    <div class="hidden lg:flex items-center px-4">
        <CTA />
    </div>
    <!-- Burger button — mobile only -->
    <button
        id="menu-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        class="flex w-auto pl-4 pr-6 h-auto justify-center items-center lg:hidden"
    >
        <div class="relative w-auto h-auto">
            <span
                id="burger-line-1"
                class="absolute top-1/2 left-0 -translate-y-1/2 w-7 h-[3px] bg-gray-700 rounded-full"
            ></span>
            <span
                id="burger-line-2"
                class="absolute top-1/2 left-0 -translate-y-1/2 w-7 h-[3px] bg-gray-700 rounded-full"
            ></span>
        </div>
    </button>
</nav>


<!-- Mobile menu overlay — full screen, controlled by GSAP -->
<div
    id="mobile-menu"
    class="fixed inset-0 z-40 flex flex-col justify-between pb-4 bg-black-900 pt-20 overflow-hidden lg:hidden"
    style="clip-path: inset(0 0 100% 0); pointer-events: none;"
>
    <ul class="flex flex-col px-6 mt-4">
        <li class="mobile-menu-item">
            <a
                href="#team"
                class="mobile-menu-link flex items-center justify-between py-5 w-full text-3xl font-bebas-neue text-gray-300 tracking-widest hover:text-accent transition-colors duration-200"
            >
                Our Team
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                    ></path></svg
                >
            </a>
        </li>
        <li class="mobile-menu-item">
            <a
                href="#branding"
                class="mobile-menu-link flex items-center justify-between py-5 w-full text-3xl font-bebas-neue text-gray-300 tracking-widest hover:text-accent transition-colors duration-200"
            >
                Branding
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                    ></path></svg
                >
            </a>
        </li>
        <li class="mobile-menu-item">
            <a
                href="#web"
                class="mobile-menu-link flex items-center justify-between py-5 w-full text-3xl font-bebas-neue text-gray-300 tracking-widest hover:text-accent transition-colors duration-200"
            >
                Web Creator
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                    ></path></svg
                >
            </a>
        </li>
        <li class="mobile-menu-item">
            <a
                href="#photography"
                class="mobile-menu-link flex items-center justify-between py-5 w-full text-3xl font-bebas-neue text-gray-300 tracking-widest hover:text-accent transition-colors duration-200"
            >
                Photography
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                    ></path></svg
                >
            </a>
        </li>
        <li class="mobile-menu-item">
            <a
                href="#videography"
                class="mobile-menu-link flex items-center justify-between py-5 w-full text-3xl font-bebas-neue text-gray-300 tracking-widest hover:text-accent transition-colors duration-200"
            >
                Videography
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                    ></path></svg
                >
            </a>
        </li>
        <li class="mobile-menu-item">
            <a
                href="#social"
                class="mobile-menu-link flex items-center justify-between py-5 w-full text-3xl font-bebas-neue text-gray-300 tracking-widest hover:text-accent transition-colors duration-200"
            >
                Social Content
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
                    ></path></svg
                >
            </a>
        </li>
    </ul>

    <p class="text-gray-300 text-sm px-6">
        We are currently in our development stage, preparing to <span
            class="text-accent">launch in September 2026</span
        >. This deliberate timeline allows us to refine compliance, strengthen
        banking relationships, and build a foundation that is as resilient as it
        is transparent.
    </p>
</div>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // ─────────────────────────────────────────────
    // INTRO CINEMATIC — Splash logo → navbar → hero
    // ─────────────────────────────────────────────
    function playIntro() {
        const splash = document.querySelector("#logo-splash");
        const splashSvg = document.querySelector("#logo-splash-svg");
        const splashLetters = document.querySelectorAll(".splash-letter");
        const logoTop = document.querySelector("#logo__top");
        const logoLink = document.querySelector("#logo-link");

        // Estado inicial oculto de todos los actores
        gsap.set("#navbar", { y: -60, opacity: 0 });
        gsap.set("#menu-desktop", { opacity: 0 });
        gsap.set(".menu-item", { opacity: 0, y: -100 });

        const tl = gsap.timeline({ defaults: { ease: "power2.out" } });

        if (splashSvg && splashLetters.length > 0) {
            gsap.set(splashSvg, { opacity: 1, scale: 0.4 });
            gsap.set(splashLetters, { opacity: 0, y: 10 });

            tl.to(splashLetters, {
                keyframes: [
                    {
                        opacity: 1,
                        y: -10,
                        duration: 0.4,
                        ease: "power2.out",
                    },
                    {
                        y: 0,
                        duration: 0.4,
                        ease: "power2.inOut",
                    },
                ],
                stagger: 0.04,
            })
                .to(splashSvg, { duration: 0.3 })
                .to(splashSvg, {
                    opacity: 0,
                    scale: 1.2,
                    duration: 0.6,
                    ease: "power2.inOut",
                })
                .to(
                    splash,
                    {
                        opacity: 0,
                        duration: 0.5,
                        ease: "power2.inOut",
                        onComplete: () => {
                            if (splash)
                                (splash as HTMLElement).style.display = "none";
                        },
                    },
                    "-=0.3",
                );
        } else {
            tl.to(splash, {
                opacity: 0,
                duration: 0.5,
                onComplete: () => {
                    if (splash) (splash as HTMLElement).style.display = "none";
                },
            });
        }

        tl.to(
            "#navbar",
            { y: 0, opacity: 1, duration: 0.8, ease: "power3.out" },
            "-=0.3",
        )
            .to(
                "#menu-desktop",
                { opacity: 1, duration: 0.5, ease: "power2.out" },
                "-=0.4",
            )
            .to(".menu-item", { opacity: 1, duration: 0.5, ease: "power3.out", stagger: 0.2 }, "-=0.4");

    }

    document.addEventListener("DOMContentLoaded", playIntro);

    // ─────────────────────────────────────────────
    // NAVBAR — Hide on scroll down, show on scroll up
    // ─────────────────────────────────────────────
    const navbar = document.querySelector("#navbar");

    if (navbar) {
        ScrollTrigger.create({
            start: "top -80",
            end: 99999,
            onUpdate: (self) => {
                if (self.direction === 1) {
                    gsap.to(navbar, {
                        y: -100,
                        duration: 0.4,
                        ease: "power2.out",
                    });
                } else {
                    gsap.to(navbar, {
                        y: 0,
                        duration: 0.5,
                        ease: "power2.out",
                    });
                }
            },
        });
    }


    // ─────────────────────────────────────────────
    // MOBILE MENU — Toggle with GSAP animation
    // ─────────────────────────────────────────────
    const menuToggle = document.querySelector("#menu-toggle");
    const mobileMenu = document.querySelector(
        "#mobile-menu",
    ) as HTMLElement | null;
    const menuItems = document.querySelectorAll(".mobile-menu-item");
    const menuCta = document.querySelector(".mobile-menu-cta");
    const line1 = document.querySelector("#burger-line-1");
    const line2 = document.querySelector("#burger-line-2");

    if (line1 && line2) {
        gsap.set(line1, { y: -5 });
        gsap.set(line2, { y: 5 });
    }

    let menuOpen = false;

    const menuTl = gsap.timeline({ paused: true });

    menuTl
        .to(mobileMenu, {
            clipPath: "inset(0 0 0% 0)",
            duration: 0.6,
            ease: "power4.inOut",
            pointerEvents: "auto",
            onStart: () => {
                if (mobileMenu) mobileMenu.style.pointerEvents = "auto";
            },
        })
        .fromTo(
            menuItems,
            { y: 20, opacity: 0 },
            {
                y: 0,
                opacity: 1,
                stagger: 0.07,
                duration: 0.45,
                ease: "power3.out",
            },
            "-=0.25",
        )
        .fromTo(
            menuCta,
            { y: 20, opacity: 0 },
            { y: 0, opacity: 1, duration: 0.4, ease: "power3.out" },
            "-=0.15",
        );

    function openMenu() {
        menuOpen = true;
        menuToggle?.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
        gsap.to(line1, {
            y: 0,
            rotate: 45,
            duration: 0.35,
            ease: "power2.inOut",
        });
        gsap.to(line2, {
            y: 0,
            rotate: -45,
            duration: 0.35,
            ease: "power2.inOut",
        });
        menuTl.play();
    }

    function closeMenu() {
        menuOpen = false;
        menuToggle?.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
        gsap.to(line1, {
            rotate: 0,
            y: -5,
            duration: 0.3,
            ease: "power2.inOut",
        });
        gsap.to(line2, {
            rotate: 0,
            y: 5,
            duration: 0.3,
            ease: "power2.inOut",
        });
        gsap.to(mobileMenu, {
            clipPath: "inset(0 0 100% 0)",
            duration: 0.5,
            ease: "power4.inOut",
            onComplete: () => {
                if (mobileMenu) mobileMenu.style.pointerEvents = "none";
                menuTl.pause(0);
            },
        });
    }

    if (menuToggle) {
        menuToggle.addEventListener("click", () =>
            menuOpen ? closeMenu() : openMenu(),
        );
    }

    document.querySelectorAll(".mobile-menu-link").forEach((link) => {
        link.addEventListener("click", () => {
            if (menuOpen) closeMenu();
        });
    });
</script>