---
import logotipo from "../assets/Logos/ruana_logo.svg";
import Item__menu from "./atoms/item__menu.astro";
import CTA from "./atoms/CTA.astro";
---

<!-- Full-screen logo splash overlay -->
<div
    id="logo-splash"
    class="fixed inset-0 z-9999 flex items-center justify-center bg-brand-secondary"
    style="pointer-events: none;"
>
    <!-- Inline SVG for animating individual letters -->
    <svg
        id="logo-splash-svg"
        class="w-[200px] opacity-0 overflow-visible"
        viewBox="0 0 126.3 105.26"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
    >
        <path class="splash-letter" d="M1.81,4.62c0-1.72-.65-3.35-1.81-4.62h16.3c4.37,0,7.94,3.57,7.94,7.94s-3.57,7.94-7.94,7.94h3.6l6.87,13.59h-11.47c.88-1.04,1.18-2.67.58-3.95l-4.87-9.64h-1.25v8.98c0,1.72.65,3.36,1.81,4.62H0c1.16-1.26,1.8-2.9,1.81-4.62V4.62ZM16.3,4.9c0-2.15-1.76-3.91-3.91-3.91h-2.64v13.89h2.64c2.15,0,3.91-1.76,3.91-3.91v-6.08Z" fill="#961728"/>
        <path class="splash-letter" d="M27.91,22.21v-12.7c0-1.72-.65-3.35-1.81-4.62h9.81c0,6.72-.07,13.44-.07,20.16-.03.14-.05.29-.05.44,0,1.1.89,2.01,2.01,2.01s2.01-.9,2.01-2.01V4.89h9.75c-1.16,1.26-1.8,2.9-1.81,4.62v15.35c0,1.72.65,3.35,1.81,4.62h-9.75v-1.68c-4.67,3.89-11.91.62-11.91-5.59Z" fill="#961728"/>
        <path class="splash-letter" d="M50.88,14.71c-.02-3.84,2.2-7.22,5.48-8.83,6.41-3.14,14.08,1.47,14.08,8.79v10.18c0,1.72.65,3.35,1.81,4.62h-9.75v-4.17c-1.55,2.04-3.91,4.17-7.03,4.17-6,0-6.44-7.87-2.16-10.42,3.31-1.98,7.48-3.89,9.19-4.65v-5.39c0-1.72-1.39-3.12-3.11-3.13-2.53-.02-4.02,2.82-2.62,4.89l-5.9,3.94ZM62.51,22.69v-6.86c-9.18,6.24-2.8,10.13,0,6.86Z" fill="#961728"/>
